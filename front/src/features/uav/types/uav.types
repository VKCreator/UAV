export interface Drone {
  drone_id: number;
  model: string;
  default_vertical_fov: number; // угол обзора (градусы)
  default_resolution_width: number;
  default_resolution_height: number;
  max_wind_resistance: number; // м/с
  max_speed: number; // м/с
  min_speed: number; // м/с
  max_battery_life: number; // минуты
  model_image_path: string | null;
}
